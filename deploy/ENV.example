# Copy to /etc/arp.env with permissions 600
NODE_ENV=production
PORT=3000

# Comma-separated list of allowed origins
CORS_ORIGINS=https://your-domain.com,https://www.your-domain.com

# Generate a fresh 64-hex secret for production
# e.g. node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=CHANGE_ME_64_HEX

# Admin credentials
ADMIN_EMAIL=admin@arp.local
# Use bcrypt hash in production; generate e.g.:
# node -e "require('bcrypt').hash(process.argv[1], 12).then(console.log)" 'YourStrongPass'
ADMIN_PASS_HASH=

